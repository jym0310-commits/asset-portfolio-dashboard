# 서버 설정
PORT=4000

# 로그인 세션 암호화에 쓰이는 비밀키 (아무 무작위 문자열이나 넣으세요, 노출되면 안 됨)
SESSION_SECRET=change-this-to-a-random-string

# 한국투자증권 Open API
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_IS_VIRTUAL=true

# Upbit API (시세 조회만 할 경우 키 불필요)
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=

# FRED (미국 연준 경제데이터) API - 경제일정 표시용, 무료 발급 (https://fred.stlouisfed.org)
FRED_API_KEY=

# Resend (비밀번호 재설정 이메일 발송용, 무료 발급 https://resend.com)
RESEND_API_KEY=
# 발신자 표시 (도메인 인증 전이면 비워두면 자동으로 onboarding@resend.dev 사용)
EMAIL_FROM=

# 재설정 링크를 만들 때 쓰는 실제 사이트 주소 (배포시 꼭 실제 주소로 바꿔주세요)
# 예: https://p01--portfolionote-1--xxxxx.code.run
APP_BASE_URL=http://localhost:4000