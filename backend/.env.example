# 서버 설정
PORT=4000

# 로그인 세션 암호화에 쓰이는 비밀키 (아무 무작위 문자열이나 넣으세요, 노출되면 안 됨)
SESSION_SECRET=change-this-to-a-random-string

# 한국투자증권 Open API
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_IS_VIRTUAL=true

# Upbit API (시세 조회만 할 경우 키 불필요)
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=

# FRED (미국 연준 경제데이터) API - 경제일정 표시용, 무료 발급 (https://fred.stlouisfed.org)
FRED_API_KEY=

# Gmail SMTP (비밀번호 재설정 이메일 발송용)
# GMAIL_USER: 발송에 쓸 본인 구글 이메일 주소
# GMAIL_APP_PASSWORD: 구글 계정 2단계인증 켠 뒤 발급받은 "앱 비밀번호" (일반 로그인 비밀번호 아님)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# 재설정 링크를 만들 때 쓰는 실제 사이트 주소 (배포시 꼭 실제 주소로 바꿔주세요)
# 예: https://p01--portfolionote-1--xxxxx.code.run
APP_BASE_URL=http://localhost:4000